{
  "name": "cosmosh",
  "version": "0.1.0+116",
  "private": true,
  "packageManager": "pnpm@10.32.0",
  "description": "A high-performance, professional-grade SSH/Terminal client built with Electron",
  "author": "agoudbg",
  "license": "GPL-3.0-only",
  "scripts": {
    "version:update": "node ./scripts/update-version.js",
    "dev:main": "pnpm --filter @cosmosh/main dev",
    "dev:profile": "node ./scripts/dev-profile.mjs",
    "dev:main:fresh": "node ./scripts/dev-profile.mjs run fresh --create --reset -- pnpm dev:main",
    "dev:renderer": "pnpm --filter @cosmosh/renderer dev",
    "dev:backend": "pnpm --filter @cosmosh/backend dev",
    "build": "pnpm -r build",
    "prepare": "node ./scripts/setup-githooks.mjs",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r --if-present lint:fix",
    "precommit:lint": "pnpm --filter @cosmosh/backend lint && pnpm --filter @cosmosh/main lint && pnpm --filter @cosmosh/renderer lint && pnpm --filter @cosmosh/i18n check && pnpm --filter @cosmosh/i18n check:sort && pnpm --filter @cosmosh/api-contract typecheck && pnpm --filter @cosmosh/api-contract lint:eslint",
    "precommit:staged": "node ./scripts/precommit-staged.mjs",
    "format": "pnpm -r format",
    "theme:sync": "pnpm --filter @cosmosh/renderer theme:sync",
    "docs:dev": "pnpm --filter @cosmosh/docs dev",
    "docs:build": "pnpm --filter @cosmosh/docs build"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=8.0.0"
  }
}
