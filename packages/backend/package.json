{
  "name": "@cosmosh/backend",
  "version": "0.1.0+116",
  "private": true,
  "type": "module",
  "description": "Cosmosh Backend API Server (Hono)",
  "main": "./dist/index.js",
  "scripts": {
    "build:runtime-deps": "pnpm --filter @cosmosh/api-contract build && pnpm --filter @cosmosh/i18n build",
    "predev": "pnpm run build:runtime-deps && prisma generate && node ../main/scripts/ensure-sqlcipher-native.cjs --runtime=node --if-needed",
    "db:generate": "prisma generate",
    "db:push": "prisma db push --skip-generate",
    "predb:init": "node ../main/scripts/ensure-sqlcipher-native.cjs --runtime=node --if-needed",
    "db:init": "tsx src/scripts/init-db.ts",
    "completion:generate": "node ./scripts/generate-inshellisense.mjs",
    "dev:runtime": "tsx src/index.ts",
    "dev:runtime:watch": "tsx watch src/index.ts",
    "dev": "pnpm run dev:runtime:watch",
    "prebuild": "pnpm run build:runtime-deps && prisma generate",
    "build": "tsc",
    "start": "node dist/index.js",
    "pretest:ssh-session": "pnpm run build:runtime-deps",
    "test:ssh-session": "tsx --test src/ssh/remote-shell-events.test.ts src/ssh/session-service.bootstrap-transport.test.ts src/ssh/session-service.remote-shell-events.test.ts src/ssh/exec.test.ts src/remote-bootstrap/service.test.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@cosmosh/api-contract": "workspace:*",
    "@cosmosh/i18n": "workspace:*",
    "@hono/node-server": "^1.19.13",
    "@prisma/adapter-better-sqlite3": "6.19.2",
    "@prisma/client": "6.19.2",
    "@prisma/driver-adapter-utils": "6.19.2",
    "better-sqlite3-multiple-ciphers": "12.6.2",
    "hono": "^4.12.25",
    "node-pty": "1.2.0-beta.11",
    "socks": "^2.8.7",
    "ssh2": "^1.17.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.4.0",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.18.1",
    "@withfig/autocomplete": "^2.692.3",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prisma": "6.19.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
