generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum SshAuthType {
  password
  key
  both
}

enum SshLoginResult {
  success
  failed
}

enum SshKeychainVisibility {
  hidden
  shared
}

enum PortForwardRuleType {
  local
  remote
  dynamic
}

model SshFolder {
  id        String      @id @default(cuid())
  name      String      @unique
  iconKey   String      @default("Folder")
  colorKey  String      @default("slate")
  note      String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  servers   SshServer[]
  keychains SshKeychain[]
}

model SshTag {
  id        String         @id @default(cuid())
  name      String         @unique
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  servers   SshServerTag[]
  keychains SshKeychainTagLink[]
}

model SshServer {
  id               String          @id @default(cuid())
  name             String
  iconKey          String          @default("Server")
  colorKey         String          @default("blue")
  host             String
  port             Int             @default(22)
  username         String
  strictHostKey    Boolean         @default(true)
  enableSshCompression Boolean      @default(false)
  keychainId       String
  note             String?
  folderId         String?
  systemHostname   String?
  systemOs         String?
  systemArch       String?
  systemKernel     String?
  lastSystemSyncAt DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  folder           SshFolder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  keychain         SshKeychain     @relation(fields: [keychainId], references: [id], onDelete: Restrict)
  tags             SshServerTag[]
  loginAudits      SshLoginAudit[]
  portForwardRules PortForwardRule[]

  @@unique([host, port, username])
  @@index([folderId])
  @@index([keychainId])
}

model SshKeychain {
  id                            String                @id @default(cuid())
  name                          String
  iconKey                       String                @default("KeyRound")
  colorKey                      String                @default("emerald")
  authType                      SshAuthType
  passwordEncrypted             String?
  privateKeyEncrypted           String?
  privateKeyPassphraseEncrypted String?
  visibility                    SshKeychainVisibility @default(hidden)
  note                          String?
  folderId                      String?
  createdAt                     DateTime              @default(now())
  updatedAt                     DateTime              @updatedAt
  folder                        SshFolder?            @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tags                          SshKeychainTagLink[]
  servers                       SshServer[]

  @@index([folderId])
}

model SshKeychainTagLink {
  keychainId String
  tagId      String
  keychain   SshKeychain @relation(fields: [keychainId], references: [id], onDelete: Cascade)
  tag        SshTag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([keychainId, tagId])
  @@index([tagId])
}

model SshKnownHost {
  id          String   @id
  host        String
  port        Int      @default(22)
  keyType     String
  fingerprint String
  trusted     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([host, port])
}

model AppSettings {
  id             String   @id @default(cuid())
  scopeAccountId String   @default("")
  scopeDeviceId  String
  payloadJson    String
  revision       Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([scopeAccountId, scopeDeviceId])
  @@index([scopeDeviceId])
}

model SshServerTag {
  serverId String
  tagId    String
  server   SshServer @relation(fields: [serverId], references: [id], onDelete: Cascade)
  tag      SshTag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([serverId, tagId])
  @@index([tagId])
}

model SshLoginAudit {
  id               String         @id @default(cuid())
  serverId         String
  attemptedAt      DateTime       @default(now())
  result           SshLoginResult
  failureReason    String?
  clientIp         String?
  sessionId        String?
  sessionStartedAt DateTime?
  sessionEndedAt   DateTime?
  commandCount     Int            @default(0)
  metadataJson     String?
  createdAt        DateTime       @default(now())
  server           SshServer      @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, attemptedAt])
}

model PortForwardRule {
  id                 String              @id @default(cuid())
  name               String
  type               PortForwardRuleType
  serverId           String
  localBindHost      String?
  localBindPort      Int?
  remoteBindHost     String?
  remoteBindPort     Int?
  targetHost         String?
  targetPort         Int?
  note               String?
  lastStartedAt      DateTime?
  lastStoppedAt      DateTime?
  lastFailureMessage String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  server             SshServer           @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@index([type])
}

model AuditEvent {
  eventId          String   @id
  occurredAt       DateTime @default(now())
  category         String
  action           String
  outcome          String
  severity         String
  scopeAccountId   String   @default("")
  scopeDeviceId    String
  entityType       String?
  entityId         String?
  sessionId        String?
  requestId        String?
  correlationId    String?
  metadataJson     String
  relatedRecordId  String?
  retentionUntilAt DateTime
  createdAt        DateTime @default(now())

  @@index([occurredAt])
  @@index([category, occurredAt])
  @@index([entityType, entityId, occurredAt])
  @@index([scopeAccountId, scopeDeviceId, occurredAt])
}

model AuditSyncCursor {
  id               String   @id @default(cuid())
  scopeAccountId   String   @default("")
  scopeDeviceId    String
  lastSyncedEventId String?
  syncedAt         DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([scopeAccountId, scopeDeviceId])
  @@index([scopeDeviceId])
}
