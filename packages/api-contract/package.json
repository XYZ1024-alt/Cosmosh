{
  "name": "@cosmosh/api-contract",
  "version": "0.1.0+116",
  "private": true,
  "description": "OpenAPI contract and generated TypeScript types for Cosmosh APIs",
  "scripts": {
    "generate": "pnpm generate:types && pnpm generate:protocol",
    "generate:types": "openapi-typescript ./openapi/cosmosh.openapi.yaml -o ./src/generated.ts && prettier --write ./src/generated.ts",
    "generate:protocol": "node ./scripts/generate-protocol.mjs",
    "build": "pnpm generate && tsup",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "pnpm generate && pnpm typecheck && pnpm lint:eslint",
    "lint:eslint": "eslint src --ext .ts",
    "lint:fix": "pnpm lint:eslint --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
